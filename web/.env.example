# Скопіюйте в web/.env.local для локальної розробки.
# У production: Vercel → Settings → Environment Variables (див. також web/lib/prisma.ts).

# Prisma Postgres / CRM: рядок підключення з Prisma Data Platform → Connect (або з Vercel env PRISMA_DATABASE_URL).
PRISMA_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Опційно: прямий Postgres (Neon тощо), якщо не використовуєте лише PRISMA_DATABASE_URL
# NEON_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Опційно: примусово використовувати DIRECT_POSTGRES_* замість PRISMA_DATABASE_URL на db.prisma.io
# USE_DATABASE_URL_FOR_PRISMA=1

# Telegram бот для зведення ФОП-платежів (@Platezi_FOP_bot).
# Реальний токен не комітити в репозиторій; додати у Vercel Environment Variables.
# TELEGRAM_PAYMENTS_BOT_TOKEN="123456:AA..."
# TELEGRAM_PAYMENTS_ADMIN_CHAT_IDS="123456789"
