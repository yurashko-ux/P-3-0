{
  "env": {
    "RUN_PRISMA_MIGRATE_ON_BUILD": "1"
  },
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/exp-check",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/photo-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/direct-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/update-direct-states",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-paid-service-dates",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-direct-altegio-metrics",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-last-visit",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/reconcile-direct-booking-kyiv-days",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/capture-warehouse-balance-snapshot",
      "schedule": "5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "finance-hob.vercel.app"
        }
      ],
      "destination": "/finance-report/login"
    },
    {
      "source": "/admin",
      "has": [
        {
          "type": "host",
          "value": "finance-hob.vercel.app"
        }
      ],
      "destination": "/admin/finance-report"
    },
    {
      "source": "/admin/:path*",
      "has": [
        {
          "type": "host",
          "value": "finance-hob.vercel.app"
        }
      ],
      "destination": "/admin/finance-report"
    }
  ]
}
